# https://github.com/dywpq/vacui
#
# Description:
#
# 		Makefile template, it's used for bare-metal libraries.
# 		The features:
#
# 			- C/C++ Standard library is not linked completely.
#
# 			- A custom linker script is used and provided
# 			by the user of Makefile template.
#
# 			- Only supports compilation of C++ sources.
#
# 			- Puts compiled main target into $(BUILD_DIR) directory.
# 
# 			- No PIC, PIE and stack protector.
#
# Customizable variables:
#
# 		CXXFLAGS 	= Additional C++ compiler flags
#
# 		ARFLAGS 	= Archive flags
#

OBJECTS := $(SOURCES:%.cxx=$(OBJECTS_DIR)/%.cxx.o)

ifeq ($(ARCH), x86-64)
CXX :=  	g++
LD := 		ld
AR := 		ar
endif

all: $(BUILD_DIR) $(OBJECTS_DIR) $(TARGET)

$(TARGET): $(OBJECTS)
	$(AR) rcs $(TARGET) $(OBJECTS)

$(OBJECTS_DIR)/%.cxx.o: %.cxx
	$(CXX) $(CXXFLAGS) $< -fno-pic -fno-pie -fno-stack-protector \
	         -nostdlib++ -nostdlib -c -ffreestanding -nostdinc -nostdinc++ -o $@

$(OBJECTS_DIR):
	mkdir -p $(OBJECTS_DIR)
$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)
clean:
	rm -fr $(OBJECTS_DIR)
	rm -fr $(BUILD_DIR)
